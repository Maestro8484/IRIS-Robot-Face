# IRIS Teensy USB device rules — persistent symlinks by hardware serial number.
# These rules survive port swaps and reboots.
#
# Deploy: sudo cp 99-iris-teensy.rules /etc/udev/rules.d/
#         sudo udevadm control --reload-rules && sudo udevadm trigger
#
# Result:
#   /dev/ttyIRIS_EYES  -> Teensy 4.1 (TeensyEyes + TFT mouth) — serial 13625440
#   /dev/ttyIRIS_SERVO -> Teensy 4.0 (servo + PAJ7620 gesture) — serial 12763490
#
# Identification is by USB hardware serial number (ATTRS{serial}), NOT by port
# position. Symlinks survive cable moves and reboots.
#
# Note (S97): serial numbers re-confirmed by connecting T41 alone and observing
# which serial appeared. S94b had these swapped — corrected here.
# T41 serial 13625440 confirmed: [VER] S97, FACE:N, EMOTION/EYE/MOUTH responses.
# T40 serial 12763490 confirmed: DIAG pan=N pajOk=N, gesture commands (VOL+, STOP, etc.)

SUBSYSTEM=="tty", ATTRS{idVendor}=="16c0", ATTRS{serial}=="13625440", SYMLINK+="ttyIRIS_EYES"
SUBSYSTEM=="tty", ATTRS{idVendor}=="16c0", ATTRS{serial}=="12763490", SYMLINK+="ttyIRIS_SERVO"
